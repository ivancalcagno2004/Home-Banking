<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UI.Views.SignUpPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#121212}">

    <ScrollView>
        <Grid VerticalOptions="Center" HorizontalOptions="Center" Padding="20">

            <Border StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light=#E5E5E5, Dark=#333333}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    WidthRequest="360"
                    Padding="32">

                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.1" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="16">

                    <VerticalStackLayout Spacing="4" Margin="0,0,0,16">
                        <Label Text="Crear una cuenta" 
                               FontAttributes="Bold"
                               FontSize="24"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                        <Label Text="Unite a Tandil Bank hoy mismo" 
                               FontSize="14"
                               TextColor="Gray"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <Label Text="Nombre Completo" TextColor="Gray" Margin="0,0,0,-8"/>
                    <Entry Text="{Binding FullName}"
                           Placeholder="Ej: Juan Pérez"
                           ClearButtonVisibility="WhileEditing"
                           HeightRequest="45"/>

                    <Label Text="Usuario" TextColor="Gray" Margin="0,0,0,-8"/>
                    <Entry Text="{Binding UserName}"
                           Placeholder="Elegí un nombre de usuario"
                           ClearButtonVisibility="WhileEditing"
                           HeightRequest="45"/>

                    <Label Text="Email" TextColor="Gray" Margin="0,0,0,-8"/>
                    <Entry Text="{Binding Email}"
                           Placeholder="ejemplo@email.com"
                           Keyboard="Email"
                           ClearButtonVisibility="WhileEditing"
                           HeightRequest="45"/>

                    <Label Text="Contraseña" TextColor="Gray" Margin="0,0,0,-8"/>
                    <Entry x:Name="TxtPasswordRegister"
                           IsPassword="True"
                           Placeholder="Creá una contraseña segura"
                           HeightRequest="45"/>

                    <Button Text="Crear mi cuenta"
                            Command="{Binding RegisterCommand}"
                            CommandParameter="{Binding Source={x:Reference TxtPasswordRegister}, Path=Text}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="45"
                            Margin="0,16,0,0"/>

                    <Button Text="¿Ya tenés cuenta? Iniciá sesión acá"
                            Command="{Binding NavigateToSignInCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Secondary}"
                            FontAttributes="Bold"
                            Margin="0,8,0,0"/>

                </VerticalStackLayout>
            </Border>
            <Grid BackgroundColor="#80000000"
              IsVisible="{Binding IsBusy}"
              ZIndex="999">

                <Grid.GestureRecognizers>
                    <TapGestureRecognizer />
                </Grid.GestureRecognizers>

                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                           Color="{StaticResource Primary}"
                           WidthRequest="60"
                           HeightRequest="60" />

                    <Label Text="Creando cuenta..." 
                       TextColor="White" 
                       FontAttributes="Bold" 
                       FontSize="16" 
                       HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>