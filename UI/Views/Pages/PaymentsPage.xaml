<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:UI.Views.Components"
             xmlns:converters="clr-namespace:HomeBanking.Data.Converters"
             x:Class="UI.Views.Pages.PaymentsPage"
             Title="Pagos"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0A0A0A}">
    
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Configuración" Clicked="OnSettingsClicked" Order="Secondary" />
        <ToolbarItem Text="Cerrar Sesión" Clicked="OnLogoutClicked" Order="Secondary" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <converters:DateToColorConverter x:Key="DateToColorConverter"/>
    </ContentPage.Resources>

    <AbsoluteLayout>

        <Grid RowDefinitions="Auto, *" Padding="20" AbsoluteLayout.LayoutBounds="0, 0, 1, 1" AbsoluteLayout.LayoutFlags="All">

            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                    <Label Text="{Binding Title}" 
                       FontSize="26" FontAttributes="Bold" 
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                    <Label Text="Tus facturas al día" 
                       FontSize="14" 
                       TextColor="#888888" Margin="0,2,0,0"/>
                </VerticalStackLayout>

                <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="10">
                    <Label Text="Historial" FontSize="14" FontAttributes="Bold" TextColor="Gray" VerticalOptions="Center"/>
                    <Switch IsToggled="{Binding ShowHistory}" OnColor="#005fb8" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>

            <CollectionView Grid.Row="1" ItemsSource="{Binding PendingPayments}" SelectionMode="None">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" 
                                 Span="{OnIdiom Desktop=3, Phone=1}" 
                                 HorizontalItemSpacing="15" 
                                 VerticalItemSpacing="15" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border Padding="20" 
                            StrokeShape="RoundRectangle 16"
                            Stroke="{AppThemeBinding Light=#EAEAEA, Dark=#222222}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#151515}">

                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#000000, Dark=#000000}" Offset="0,2" Radius="8" Opacity="{AppThemeBinding Light=0.03, Dark=0.1}" />
                            </Border.Shadow>

                            <Grid RowDefinitions="*, Auto, *" RowSpacing="16">

                                <Grid Grid.Row="0" ColumnDefinitions="Auto, *">
                                    <Border Grid.Column="0" WidthRequest="46" HeightRequest="46" 
                                        StrokeShape="RoundRectangle 23" 
                                        BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#002244}" 
                                        Stroke="Transparent" Margin="0,0,15,0">
                                        <Label Text="{Binding ServiceName[0]}" 
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           FontAttributes="Bold" TextColor="#005fb8" FontSize="18"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding ServiceName}" FontAttributes="Bold" FontSize="16" 
                                           LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                                        <Label Text="{Binding CategoryName}" FontSize="13" TextColor="#888888"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <Grid Grid.Row="1" ColumnDefinitions="*, Auto" VerticalOptions="End">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="Monto a pagar" FontSize="12" TextColor="#888888" Margin="0,0,0,2"/>
                                        <Label Text="{Binding Amount, StringFormat='${0:N2}'}" 
                                           FontSize="24" FontAttributes="Bold" 
                                           TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="End">

                                        <VerticalStackLayout HorizontalOptions="End">
                                            <VerticalStackLayout.Triggers>
                                                <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding IsPaid}" Value="True">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </VerticalStackLayout.Triggers>
                                            <Label Text="Vencimiento" FontSize="11" TextColor="#888888" HorizontalOptions="End"/>
                                            <Label Text="{Binding ExpDate, StringFormat='{0:dd MMM yyyy}'}" FontSize="13" FontAttributes="Bold" HorizontalOptions="End" TextColor="{Binding ExpDate, Converter={StaticResource DateToColorConverter}}"/>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout HorizontalOptions="End" IsVisible="False">
                                            <VerticalStackLayout.Triggers>
                                                <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding IsPaid}" Value="True">
                                                    <Setter Property="IsVisible" Value="True"/>
                                                </DataTrigger>
                                            </VerticalStackLayout.Triggers>
                                            <Label Text="Abonado el" FontSize="11" TextColor="#888888" HorizontalOptions="End"/>
                                            <Label Text="{Binding PaymentDate, StringFormat='{0:dd MMM yyyy}'}" FontSize="13" FontAttributes="Bold" TextColor="#198754" HorizontalOptions="End"/>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,5,0,0">

                                    <Button Text="Pagar Ahora" 
                                        BackgroundColor="#005fb8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        CornerRadius="22"
                                        HeightRequest="44"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PayCommand}"
                                        CommandParameter="{Binding}">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsPaid}" Value="True">
                                                <Setter Property="IsVisible" Value="False"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <Border BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#0F291E}" 
                                        Stroke="{AppThemeBinding Light=#C8E6C9, Dark=#1B4532}" 
                                        StrokeShape="RoundRectangle 22" 
                                        HeightRequest="44" IsVisible="False">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsPaid}" Value="True">
                                                <Setter Property="IsVisible" Value="True"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                                            <Label Text="✓" FontAttributes="Bold" TextColor="#198754" VerticalOptions="Center" FontSize="16"/>
                                            <Label Text="PAGADO" FontAttributes="Bold" TextColor="#198754" VerticalOptions="Center" FontSize="13" CharacterSpacing="1"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
        <components:FloatingChatView AbsoluteLayout.LayoutBounds="1, 1, AutoSize, AutoSize" AbsoluteLayout.LayoutFlags="PositionProportional" Margin="20"/>
    </AbsoluteLayout>
</ContentPage>