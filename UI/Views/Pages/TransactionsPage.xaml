<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UI.Views.Pages.TransactionsPage"
             Title="Movimientos"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#121212}">

    <Grid RowDefinitions="Auto, *" Padding="20">

        <VerticalStackLayout Grid.Row="0" Margin="0,0,0,20">
            <Label Text="Últimos Movimientos" 
                   FontSize="24" FontAttributes="Bold" 
                   TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
            <Label Text="Historial de tus operaciones" 
                   FontSize="14" 
                   TextColor="Gray"/>
        </VerticalStackLayout>

        <Border Grid.Row="1" 
                StrokeShape="RoundRectangle 12"
                Stroke="{AppThemeBinding Light=#E5E5E5, Dark=#333333}"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" />
            </Border.Shadow>

            <CollectionView ItemsSource="{Binding Transactions}" SelectionMode="None">

                <CollectionView.Header>
                    <Grid ColumnDefinitions="90, *, Auto" Padding="15,15,15,10">
                        <Label Grid.Column="0" Text="Fecha" FontAttributes="Bold" TextColor="Gray" FontSize="12"/>
                        <Label Grid.Column="1" Text="Detalle" FontAttributes="Bold" TextColor="Gray" FontSize="12"/>
                        <Label Grid.Column="2" Text="Monto" FontAttributes="Bold" TextColor="Gray" FontSize="12" HorizontalOptions="End"/>
                    </Grid>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="90, *, Auto" Padding="15,15">

                            <BoxView Grid.ColumnSpan="3" 
                                     HeightRequest="1" 
                                     Color="{AppThemeBinding Light=#F0F0F0, Dark=#2C2C2C}" 
                                     VerticalOptions="End" 
                                     Margin="-15,-15,-15,-15"/>

                            <Label Grid.Column="0" 
                                   Text="{Binding Date, StringFormat='{0:dd/MM/yyyy}'}" 
                                   TextColor="Gray" 
                                   FontSize="13"
                                   VerticalOptions="Center"/>

                            <Label Grid.Column="1" 
                                   Text="{Binding Description}" 
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                   VerticalOptions="Center"/>

                            <Border Grid.Column="2" 
                                    Padding="10,5" 
                                    StrokeShape="RoundRectangle 6" 
                                    BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2A2A2A}" 
                                    Stroke="Transparent" 
                                    VerticalOptions="Center">

                                <Label Text="{Binding Amount}" 
                                       TextColor="{Binding Color}" 
                                       FontAttributes="Bold" 
                                       HorizontalOptions="End"/>
                            </Border>

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>
    </Grid>
</ContentPage>