<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UI.Views.Pages.SettingsPage"
             Title="Configuración"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#121212}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Cerrar Sesión" Clicked="OnLogoutClicked" Order="Secondary" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *" Padding="20">

        <VerticalStackLayout Grid.Row="0" Margin="0,0,0,20">
            <Label Text="Configuración" 
                   FontSize="24" FontAttributes="Bold" 
                   TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
            <Label Text="Administrá tu perfil y preferencias" 
                   FontSize="14" 
                   TextColor="Gray"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" MaximumWidthRequest="700" HorizontalOptions="Center">

                <VerticalStackLayout Spacing="8">
                    <Label Text="Mi Perfil" FontAttributes="Bold" TextColor="Gray"/>

                    <Border Padding="20" 
                            StrokeShape="RoundRectangle 12"
                            Stroke="{AppThemeBinding Light=#E5E5E5, Dark=#333333}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">

                            <Border Grid.Column="0" WidthRequest="60" HeightRequest="60" 
                                StrokeShape="RoundRectangle 30" 
                                BackgroundColor="#005fb8" 
                                Stroke="Transparent">
                                <Label Text="{Binding Initials}" 
                                   TextColor="White" FontSize="24" FontAttributes="Bold" 
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">

                                <Label Text="{Binding FullName}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                   LineBreakMode="TailTruncation" 
                                   MaxLines="1"/>

                                <Label Text="{Binding Email}" 
                                   FontSize="14" 
                                   TextColor="Gray" 
                                   LineBreakMode="TailTruncation" 
                                   MaxLines="1"/>
                            </VerticalStackLayout>

                            <Button Grid.Column="2" 
                                Text="Editar" 
                                BackgroundColor="Transparent"
                                TextColor="#005fb8"
                                BorderColor="#005fb8"
                                BorderWidth="1"
                                CornerRadius="8"
                                HeightRequest="40"
                                Padding="15,0"
                                VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Preferencias de la App" FontAttributes="Bold" TextColor="Gray"/>

                    <Border Padding="20" 
                            StrokeShape="RoundRectangle 12"
                            Stroke="{AppThemeBinding Light=#E5E5E5, Dark=#333333}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="15">

                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Modo Oscuro" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                    <Label Text="Cambiar la apariencia de la aplicación" FontSize="12" TextColor="Gray"/>
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" IsToggled="{Binding IsDarkMode}" OnColor="#005fb8" Toggled="OnThemeSwitchToggled"/>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E5E5E5, Dark=#333333}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Notificaciones" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                    <Label Text="Recibir alertas de transferencias y pagos" FontSize="12" TextColor="Gray"/>
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" IsToggled="{Binding NotificationsEnabled}" OnColor="#005fb8"/>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8" Margin="0,10,0,0">
                    <Label Text="Acerca de" FontAttributes="Bold" TextColor="Gray"/>

                    <Border Padding="20" 
                            StrokeShape="RoundRectangle 12"
                            Stroke="{AppThemeBinding Light=#E5E5E5, Dark=#333333}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

                        <HorizontalStackLayout Spacing="15">
                            <Label Text="ℹ️" FontSize="24" VerticalOptions="Center"/>
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="Tandil Bank App" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                <Label x:Name="VersionLabel" TextColor="Gray" />
                                <Label Text="© 2026 Tandil Bank S.A. By Jano" Margin="0,5,0,0" FontSize="12" TextColor="Gray"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>